# Base de datos (Supabase PostgreSQL via pooler)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-us-east-2.pooler.supabase.com:5432/postgres"

# Supabase (client-side)
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# OpenCode Zen - IA (deepseek-v4-flash-free)
ZEN_API_KEY=sk-your-key-here

# URL base (para redirects OAuth y enlaces absolutos)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
